		"@astrojs/vercel": "^10.0.4",
		"@fortawesome/fontawesome-pro": "^6.5.1",
		"@fortawesome/fontawesome-svg-core": "^6.5.1",
		"@fortawesome/free-brands-svg-icons": "^6.5.1",
		"@fortawesome/pro-solid-svg-icons": "^6.5.1",
